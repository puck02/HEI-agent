# === Application ===
APP_NAME=hel-agent
APP_ENV=development
DEBUG=true

# === Server ===
HOST=0.0.0.0
PORT=8000

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql+asyncpg://helagent:helagent_password@localhost:5432/helagent
DATABASE_URL_SYNC=postgresql://helagent:helagent_password@localhost:5432/helagent
POSTGRES_USER=helagent
POSTGRES_PASSWORD=helagent_password
POSTGRES_DB=helagent

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Qdrant ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# === JWT Auth ===
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# === LLM Providers (add keys for providers you want to use) ===
# Priority order: deepseek > glm > openai (auto-failover)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === Embedding ===
EMBEDDING_PROVIDER=glm
EMBEDDING_MODEL=embedding-3

# === RAG ===
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_RERANK_TOP_K=20

# === Memory ===
SHORT_TERM_MEMORY_TTL=86400
SHORT_TERM_MEMORY_MAX_TURNS=20
LONG_TERM_MEMORY_DECAY_RATE=0.95

# === MCP Tools ===
WEATHER_API_KEY=
SEARCH_API_KEY=
